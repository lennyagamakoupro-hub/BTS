# Variables d'environnement — copier en `.env` et adapter
MONGO_URL=mongodb://localhost:27017
MONGO_DB=lenny
# Origines autorisées (CORS). En prod, mettre l'URL exacte du front.
CORS_ORIGINS=*
# Jeton administrateur (formateur) — REQUIS pour les routes admin
# (/api/feedback/admin, POST/DELETE /api/updates). Sans lui, ces routes
# renvoient 503. Génère un secret long : openssl rand -hex 24
# Le même jeton sera demandé à Lenny dans le navigateur (saisi une seule fois).
ADMIN_TOKEN=change-moi-pour-un-secret-long-et-aleatoire

# --- Chatbot Lenny-agent : IA de secours (OPTIONNEL) ---
# Sans clé, /api/chat renvoie {ok:false, reason:"no_ai"} et le chatbot
# fonctionne en base de connaissances seule (gratuit). Pour activer l'IA :
# ANTHROPIC_API_KEY=sk-ant-...
# Modèle utilisé (modifiable) :
# LENNY_AI_MODEL=claude-haiku-4-5

